{
  "dependencies": {
    "dotenv": "^16.4.4",
    "next": "^13.1.6",
    "node-pg-migrate": "^6.2.2",
    "pg": "^8.11.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "name": "cyberworlds",
  "version": "1.0.0",
  "description": "Projeto com intuito de apreder a contruir uma aplicação web de fora a fora",
  "main": "index.js",
  "scripts": {
    "dev": "npm run lint:fix && npm run services:up && next dev",
    "services:up": "sudo docker-compose -f infra/compose.yaml up -d",
    "services:down": "sudo docker-compose -f infra/compose.yaml down",
    "services:stop": "sudo docker-compose -f infra/compose.yaml stop",
    "lint:check": "prettier --check .",
    "lint:fix": "prettier --write .",
    "test": "jest",
    "test:watch": "jest --watchAll",
    "migration:create": "node-pg-migrate -m infra/migrations create",
    "migration:up": "node-pg-migrate -m infra/migrations --envPATH .env up"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "jest": "^29.6.2",
    "prettier": "^3.6.2"
  }
}
